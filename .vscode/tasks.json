{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Serve Ollama",
            "type": "shell",
            "icon": {
                "id": "robot",
                "color": "terminal.ansiBlue"
            },
            "command": "ollama serve"
        },
        {
            "label": "Run App",
            "type": "shell",
            "icon": {
                "id": "play",
                "color": "terminal.ansiGreen"
            },
            "command": "./scripts/run.sh",
            "options": {
                "cwd": "${workspaceFolder}"
            }
        }
    ]
}